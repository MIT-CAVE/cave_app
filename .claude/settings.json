
{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Read(./cave_api/**)",
      "Edit(./cave_api/**)",
      "Write(./cave_api/**)",
      "Read(./cave_app/**)",
      "Edit(./cave_app/**)",
      "Write(./cave_app/**)",
      "Read(./cave_core/**)",
      "Edit(./cave_core/**)",
      "Write(./cave_core/**)",
      "Read(./README.md)",
      "Edit(./README.md)",
      "Write(./README.md)"
    ],
    "deny": [
      "Read(.env)",
      "Read(*.env*)",
      "Read(**/*.env*)",
      "Read(**/*key*/**)",
      "Read(**/secret/**)",
      "Bash(rm *)",
      "Bash(git *)",
      "Read(cache/**)",
      "Read(dist/**)",
      "Read(**/__pycache__/**)",
      "Read(**/venv/**)"
    ]
  }
}